enum AuthType {
    OAUTH
    CREDENTIALS
}

model User {
    id         String    @id @default(cuid())
    name       String
    email      String
    profilePic String
    type       AuthType
    password   String
    employee   Employee?
    sessions   Session[]
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
}
