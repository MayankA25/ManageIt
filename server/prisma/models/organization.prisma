enum OrganizationStatus {
    PENDING
    ACTIVE
    SUSPENDED
    DEACTIVATED
}

model Organization {
    id           String             @id @default(cuid())
    name         String
    slug         String
    website      String
    logo         String
    contactEmail String
    contactPhone String
    status       OrganizationStatus
    trust        Trust?
    regions      Region[]
}

model Trust {
    id                    String       @id @default(cuid())
    score                 Int
    customDomainVerifed   Boolean
    employeeVerifications Int
    organizationId        String       @unique
    organization          Organization @relation(fields: [organizationId], references: [id])
}
